{
    "bindings": [
        {
            "authLevel": "function",
            "type": "httpTrigger",
            "direction": "in",
            "name": "req",
            "methods": [
                "post"
            ]
        },
        {
            "type": "http",
            "direction": "out",
            "name": "res"
        },
        {
            "type": "queue",
            "name": "outputMsg",
            "direction": "out",
            "connection": "AzureWebJobsStorage",
            "queueName": "e2e-test-queue-trigger"
        }
    ],
    "scriptFile": "../dist/httpTriggerStorageQueueOutput/index.js"
}
